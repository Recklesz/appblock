{
  "manifest_version": 3,
  "name": "Local Site Blocker",
  "description": "Block and unblock distracting websites locally in Chrome.",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Local Site Blocker",
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "options_page": "options/options.html"
}
